{
  "name": "314oner.github.io",
  "version": "0.0.2",
  "private": true,
  "author": "Alexander Gverdtsiteli",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/314oner/314oner.github.io/issues"
  },
  "homepage": "https://github.com/314oner/314oner.github.io#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/314oner/314oner.github.io.git"
  },
  "scripts": {
    "docs": "docusaurus",
    "docs:start": "docusaurus start",
    "docs:build": "docusaurus build",
    "docs:swizzle": "docusaurus swizzle",
    "docs:deploy": "docusaurus deploy",
    "docs:clear": "docusaurus clear",
    "docs:serve": "docusaurus serve",
    "docs:write-translations": "docusaurus write-translations",
    "docs:write-heading-ids": "docusaurus write-heading-ids",
    "server": "json-server --watch ./apps/json-server/src/db/index.js --routes ./apps/json-server/src/routes.json --port 3001",
    "apps:dev": "yarn workspaces foreach -v -i -ptv --include '*-app' run dev",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@docusaurus/core": "2.4.3",
    "@docusaurus/preset-classic": "2.4.3",
    "@mdx-js/react": "^1.6.22",
    "clsx": "^1.2.1",
    "prism-react-renderer": "^1.3.5",
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "2.4.3",
    "@tsconfig/docusaurus": "^1.0.5",
    "json-server": "^0.17.4",
    "typescript": "^4.7.4"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=16.14"
  },
  "workspaces": [
    "apps/*"
  ],
  "packageManager": "yarn@4.0.0-rc.44"
}
