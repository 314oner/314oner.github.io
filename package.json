{
  "name": "314oner.github.io",
  "version": "0.0.3",
  "private": true,
  "author": "Alexander Gverdtsiteli",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/314oner/314oner.github.io/issues"
  },
  "homepage": "https://github.com/314oner/314oner.github.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/314oner/314oner.github.io.git"
  },
  "scripts": {
    "docs": "docusaurus",
    "docs:start": "docusaurus start",
    "docs:build": "docusaurus build",
    "docs:swizzle": "docusaurus swizzle",
    "docs:deploy": "docusaurus deploy",
    "docs:clear": "docusaurus clear",
    "docs:serve": "docusaurus serve",
    "docs:write-translations": "docusaurus write-translations",
    "docs:write-heading-ids": "docusaurus write-heading-ids",
    "transpile": "tsc -b",
    "server": "node --loader ts-node/esm ./apps/json-server/json-server.ts --watch ./build/db/index.js --routes ./apps/json-server/src/routes.json --port 3001",
    "apps:build": "yarn workspaces foreach -v -i -ptv --include '@apps/*' run build",
    "apps:dev": "yarn workspaces foreach -v -i -ptv --include '@apps/*' run dev",
    "servers:build": "yarn workspaces foreach -v -i -ptv --include '@servers/*' run build",
    "build": "npm run apps:build && shx cp build/index.html build/404.html && npm run servers:build",
    "build:clean": "rm -rf ./packages/*/lib ./apps/*/lib && yarn transpile",
    "lint": "tslint --project ./packages/tsconfig.lint.json",
    "lint:fix": "tslint --project ./packages/tsconfig.lint.json --fix"
  },
  "dependencies": {
    "@docusaurus/core": "^2.4.3",
    "@docusaurus/preset-classic": "^2.4.3",
    "@mdx-js/react": "^1.6.22",
    "clsx": "^1.2.1",
    "prism-react-renderer": "^1.3.5",
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "2.4.3",
    "@tsconfig/docusaurus": "^1.0.5",
    "gh-pages": "^6.0.0",
    "json-server": "0.17.4",
    "shx": "0.3.4",
    "ts-node": "10.9.1",
    "tslint": "^6.1.3",
    "typescript": "^5.2.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=16.14"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "yarn@4.0.0-rc.44"
}