{
  "extends": "@tsconfig/docusaurus/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "~/*": [
        "./apps/*"
      ],
      "~/public/*": [
        "./public/*"
      ]
    },
  },
  "include": [
    "apps/**/*"
  ],
  "exclude": [
    "node_modules"
  ],
}