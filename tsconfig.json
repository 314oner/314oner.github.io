{
  "extends": "@tsconfig/docusaurus/tsconfig.json",
  "files": [],
  "references": [
    {
      "path": "apps/json-server"
    },
    {
      "path": "apps/rsc-v8-app"
    },
    {
      "path": "apps/static-preact-app"
    },
    {
      "path": "packages/pkg1"
    },
    {
      "path": "packages/pkg2"
    },
    {
      "path": "packages/pkg3"
    }
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "skipLibCheck": true,
    "paths": {
      "@/*": [
        "./packages/*",
        "./apps/*",
      ]
    },
  },
  "include": [
    "apps/*",
    "packages/*",
  ],
  "exclude": [
    "node_modules"
  ],
}