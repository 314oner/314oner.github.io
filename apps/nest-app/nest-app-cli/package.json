{
  "name": "@nest-app/cli",
  "version": "1.0.0-development",
  "private": true,
  "author": "Alexander Gverdtsiteli",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/314oner/314oner.github.io/issues"
  },
  "homepage": "https://github.com/314oner/314oner.github.io#readme",
  "main": "lib/index.js",
  "bin": "./lib/cli.js",
  "scripts": {
    "prepare": "turbo run typegen --filter @nest-app/cli --output-logs errors-only",
    "dev": "npx ts-node -r dotenv/config lib/cli.js",
    "build": "pnpm run clean && tsc --project tsconfig.json",
    "clean": "rimraf ./lib ./tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@nest-app/api": "1.0.0",
    "@nest-app/microservice-api2": "1.0.0",
    "@nest-app/microservice-api3": "1.0.0",
    "@nest-app/microservice-api4": "1.0.0",
    "commander": "^4.0.0",
    "ts-node": "^10.0.0"
  },
  "devDependencies": {
    "rimraf": "5.0.1",
    "turbo": "1.10.16",
    "typescript": "5.2.2"
  },
  "engines": {
    "node": "18",
    "pnpm": "8"
  },
  "packageManager": "pnpm@8.12.1",
  "volta": {
    "extends": "../../../package.json"
  },
  "workspaces": [
    "../nest-app-api",
    "../nest-app-core",
    "../nest-microservice-api2",
    "../nest-microservice-api3",
    "../nest-microservice-api4"
  ]
}