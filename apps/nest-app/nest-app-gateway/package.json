{
  "name": "@apps/nest-app-gateway",
  "version": "3.0.2",
  "main": "dist/main.js",
  "typings": "dist/main.d.ts",
  "description": "description",
  "author": "",
  "license": "MIT",
  "scripts": {
    "prepare": "turbo run build --filter @apps/nest-app-gateway --output-logs errors-only",
    "prebuild": "rimraf dist",
    "build": "pnpm run clean && node --max-old-space-size=1500 ../../../node_modules/.bin/tsc -p tsconfig.build.json",
    "clean": "rimraf ./dist ./coverage ./tsconfig.build.tsbuildinfo"
  },
  "dependencies": {
    "@apps/nest-app-shared": "^1.1.70",
    "@nestjs/common": "10.3.3",
    "@nestjs/config": "3.2.0",
    "@nestjs/core": "10.3.3",
    "@nestjs/microservices": "10.3.3",
    "@nestjs/platform-express": "10.3.3",
    "@nestjs/swagger": "7.3.0",
    "@nestjs/typeorm": "10.0.2",
    "chalk": "4.1.2",
    "dayjs": "1.11.10",
    "express": "4.18.3",
    "log4js": "4.5.1",
    "reflect-metadata": "0.2.1",
    "rxjs": "7.8.1",
    "sqlite3": "5.1.7",
    "stacktrace-js": "2.0.2",
    "typeorm": "0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "10.3.2",
    "@nestjs/schematics": "10.1.1",
    "@types/express": "4.17.21",
    "@types/node": "18",
    "dotenv": "16.4.5",
    "rimraf": "5.0.5",
    "source-map-support": "0.5.21",
    "ts-loader": "9.5.1",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.3.0",
    "@types/chai": "*",
    "@types/faker": "*",
    "@types/graphql": "*",
    "@types/mocha": "*",
    "@types/passport-google-oauth": "*",
    "@types/passport-jwt": "*",
    "@types/sinon": "*",
    "@types/supertest": "*",
    "chai": "^4.2.0",
    "faker": "^5.1.0",
    "mocha": "^8.1.1",
    "nodemon": "3.1.0",
    "sinon": "^9.0.2",
    "superagent": "^6.0.0",
    "superagent-defaults": "^0.1.14",
    "supertest": "^5.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "yarn lint",
      "prettier --ignore-path .eslintignore --write"
    ],
    "{*.json,.{babelrc,eslintrc,prettierrc,stylelintrc}}": [
      "prettier --ignore-path .eslintignore --parser json --write"
    ],
    "*.{html,md,yml}": [
      "prettier --ignore-path .eslintignore --single-quote --write"
    ]
  }
}