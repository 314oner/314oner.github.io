FROM bitnami/kafka:latest
ARG BROKER_ID=1
ARG PLAINTEXT_LISTENER=yes
ARG CFG_LISTENER_SECURITY_PROTOCOL_MAP=CONTROLLER:PLAINTEXT,PLAINTEXT:PLAINTEXT
ARG CFG_LISTENERS=PLAINTEXT://:9092,CONTROLLER://:9093
ARG CFG_ADVERTISED_LISTENERS=CLIENT:PLAINTEXT://127.0.0.1:9092
ARG INTER_BROKER_LISTENER_NAME=CLIENT
ARG CFG_CONTROLLER_QUORUM_VOTERS=1@localhost:9093
ARG CFG_CONTROLLER_LISTENER_NAMES=CONTROLLER
ARG CFG_NODE_ID=1
ARG KRAFT_CLUSTER_ID=tmvHlRn_RaqIrOyfzajG9w

ENV KAFKA_BROKER_ID="${BROKER_ID}"
ENV ALLOW_PLAINTEXT_LISTENER="${PLAINTEXT_LISTENER}"
ENV KAFKA_CFG_LISTENER_SECURITY_PROTOCOL_MAP="${CFG_LISTENER_SECURITY_PROTOCOL_MAP}"
ENV KAFKA_CFG_LISTENERS="${CFG_LISTENERS}"
ENV KAFKA_CFG_ADVERTISED_LISTENERS="${CFG_ADVERTISED_LISTENERS}"
ENV KAFKA_INTER_BROKER_LISTENER_NAME="${INTER_BROKER_LISTENER_NAME}"
ENV KAFKA_CFG_CONTROLLER_QUORUM_VOTERS="${CFG_CONTROLLER_QUORUM_VOTERS}"
ENV KAFKA_CFG_CONTROLLER_LISTENER_NAMES="${CFG_CONTROLLER_LISTENER_NAMES}"
ENV KAFKA_CFG_NODE_ID="${CFG_NODE_ID}"
ENV KAFKA_KRAFT_CLUSTER_ID="${KRAFT_CLUSTER_ID}"


EXPOSE 9092