{
  "name": "@nest-app/api",
  "description": "web server and application server to which microservices are connected",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "git@gitflic.ru:aleksandrgverdtciteli/portfolio-fullstack-application.git"
